{
  "name": "robot-host-app",
  "version": "1.0.0",
  "description": "Host Control Software for Pipeline Robot",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.robotsoft.hostapp",
    "productName": "Pipeline Robot Control",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "dist",
      "buildResources": "src/assets"
    },
    "files": [
      "src/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
